---
const posts=[
  {title:"Chaining Email Enumeration to Full DB Dump",date:"2026",tags:["SSRF","Brute Force","Data Exposure"],excerpt:"How I combined email enumeration, credential brute force, and SSRF into a chain that led to a complete database dump of 7,000+ records.",status:"coming-soon"},
  {title:"DOM Clobbering + Cross-Origin Exploit Chain",date:"2026",tags:["XSS","DOM Clobbering","Challenge"],excerpt:"Walkthrough of the Intigriti March 2026 XSS challenge — DOM clobbering with cross-origin window.open for code execution.",status:"coming-soon"},
  {title:"Android Pentesting Without Root — FridHunter",date:"2026",tags:["Android","Frida","Mobile Security"],excerpt:"Building a rootless Android pentesting framework using Frida Gadget injection on Termux.",status:"coming-soon"},
];
---
<section class="section blog" id="blog"><div class="container">
  <div data-animate><span class="section-label">05 / Writeups</span><h2 class="section-title">Blog & Writeups</h2><p class="section-subtitle" style="margin-bottom:3rem">Security research, vulnerability writeups, and technical deep-dives.</p></div>
  <div class="blog__grid">{posts.map((p,i)=>(
    <div class="card" data-animate style={`transition-delay:${i*.1}s`}>
      <div class="blog__top"><span class="blog__date">{p.date}</span>{p.status==='coming-soon'&&<span class="blog__soon">Coming Soon</span>}</div>
      <h3 class="blog__title">{p.title}</h3>
      <p class="blog__excerpt">{p.excerpt}</p>
      <div class="blog__tags">{p.tags.map(t=>(<span class="tag">{t}</span>))}</div>
    </div>
  ))}</div>
</div></section>
<style>
  .blog__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.5rem}
  .blog__top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem}
  .blog__date{font-family:var(--font-mono);font-size:.75rem;color:var(--text-muted)}
  .blog__soon{font-family:var(--font-mono);font-size:.65rem;color:var(--orange);padding:.25rem .6rem;background:rgba(255,165,2,.1);border:1px solid rgba(255,165,2,.15);border-radius:100px;text-transform:uppercase;letter-spacing:.05em}
  .blog__title{font-family:var(--font-display);font-size:1.2rem;font-weight:700;line-height:1.3;margin-bottom:.75rem;transition:color .2s}
  .card:hover .blog__title{color:var(--accent)}
  .blog__excerpt{color:var(--text-secondary);font-size:.9rem;line-height:1.7;margin-bottom:1rem;flex:1}
  .blog__tags{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:auto}
  @media(max-width:768px){.blog__grid{grid-template-columns:1fr}}
</style>
