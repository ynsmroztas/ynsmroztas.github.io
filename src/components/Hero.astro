<section class="hero" id="hero">
  <div class="glow-orb glow-orb--green" style="position:absolute;top:-10%;right:-5%"></div>
  <div class="glow-orb glow-orb--purple" style="position:absolute;bottom:10%;left:-5%"></div>
  <div class="container hero__c">
    <div class="hero__content">
      <div class="hero__status" data-animate><span class="hero__dot"></span>Available for collaboration & bug bounty programs</div>
      <h1 class="hero__title" data-animate>
        <span class="hero__line" id="tw1"></span>
        <span class="hero__line" id="tw2"></span>
      </h1>
      <p class="hero__sub" data-animate>
        Hi, I'm <strong>Yunus Emre Öztaş</strong> — bug bounty hunter recognized by
        <span class="hero__hl">Apple</span>, <span class="hero__hl">Microsoft</span>,
        <span class="hero__hl">Meta</span> & <span class="hero__hl">IBM</span>.
        Intigriti Top Hacker. Building offensive tools and finding critical vulnerabilities before the bad guys do.
      </p>
      <div class="hero__badges" data-animate>
        <span class="tag">★ Intigriti Top Hacker</span><span class="tag tag--purple">Apple HOF</span>
        <span class="tag tag--purple">Microsoft MSRC</span><span class="tag">Meta Bug Bounty</span><span class="tag tag--purple">IBM HOF</span>
      </div>
      <div class="hero__actions" data-animate>
        <a href="#hof" class="btn btn--primary">View Achievements ↗</a>
        <a href="#tools" class="btn btn--outline">Open Source Tools</a>
      </div>
    </div>
    <div class="hero__terminal" data-animate="right">
      <div class="terminal" style="box-shadow:0 25px 80px rgba(0,0,0,.5)">
        <div class="terminal__header"><span class="terminal__dot terminal__dot--red"></span><span class="terminal__dot terminal__dot--yellow"></span><span class="terminal__dot terminal__dot--green"></span><span class="terminal__title">mitsec@kali — ~/recon</span></div>
        <div class="terminal__body">
          <div><span class="terminal__prompt">$</span> whoami</div>
          <div style="color:var(--accent)">mitsec — security researcher & developer</div>
          <div><span class="terminal__prompt">$</span> cat /etc/specialties</div>
          <div style="color:var(--orange)">web_appsec | mobile_pentest | bug_bounty</div>
          <div><span class="terminal__prompt">$</span> ls ./achievements/</div>
          <div style="color:var(--orange)">apple_hof/ microsoft_msrc/ meta_bounty/ ibm_hof/</div>
          <div><span class="terminal__prompt">$</span> <span style="animation:blink 1s step-end infinite;color:var(--accent)">_</span></div>
        </div>
      </div>
    </div>
  </div>
  <div class="hero__scroll"><span>Scroll</span><div class="hero__scroll-line"></div></div>
</section>
<style>
  .hero{min-height:100vh;display:flex;align-items:center;position:relative;padding-top:5rem}
  .hero__c{display:grid;grid-template-columns:1.1fr .9fr;gap:4rem;align-items:center;position:relative;z-index:1}
  .hero__status{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--font-mono);font-size:.78rem;color:var(--text-secondary);margin-bottom:1.5rem;padding:.5rem 1rem;background:var(--accent-dim);border:1px solid rgba(0,255,136,.1);border-radius:100px;width:fit-content}
  .hero__dot{width:7px;height:7px;background:var(--accent);border-radius:50%;animation:pulse 2s ease-in-out infinite;box-shadow:0 0 8px var(--accent-glow)}
  .hero__title{font-family:var(--font-display);font-size:clamp(3rem,7vw,5.5rem);font-weight:900;line-height:1;letter-spacing:-.04em;margin-bottom:1.5rem;min-height:calc(clamp(3rem,7vw,5.5rem)*2)}
  .hero__line{display:block}.tw-cursor{display:inline-block;width:3px;height:1em;background:var(--accent);animation:blink .7s step-end infinite;vertical-align:text-bottom;margin-left:2px}
  .hero__sub{font-size:1.1rem;color:var(--text-secondary);line-height:1.8;max-width:520px;margin-bottom:2rem}
  .hero__sub strong{color:var(--text-primary)}.hero__hl{color:var(--accent);font-weight:500}
  .hero__badges{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2.5rem}
  .hero__actions{display:flex;gap:1rem}
  .hero__scroll{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;font-family:var(--font-mono);font-size:.7rem;color:var(--text-muted);letter-spacing:.15em;text-transform:uppercase}
  .hero__scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--accent),transparent);animation:pulse 2s ease-in-out infinite}
  @media(max-width:968px){.hero__c{grid-template-columns:1fr;gap:3rem}.hero__terminal{max-width:500px}}
  @media(max-width:768px){
    .hero{padding-top:5.5rem;min-height:auto;padding-bottom:3rem}
    .hero__title{font-size:clamp(2.2rem,8vw,3.5rem);min-height:auto}
    .hero__sub{font-size:1rem}
    .hero__badges{gap:.35rem}
    .hero__actions{flex-direction:column;gap:.75rem}
    .hero__actions .btn{text-align:center;justify-content:center;width:100%}
    .hero__scroll{display:none}
    .hero__status{font-size:.7rem;padding:.4rem .75rem}
  }
  @media(max-width:480px){
    .hero{padding-top:5rem;padding-bottom:2rem}
    .hero__title{font-size:2rem}
  }
</style>
<script>
  const l1=document.getElementById('tw1'),l2=document.getElementById('tw2');let i=0,j=0;
  function t1(){if(i<='Security'.length){l1.innerHTML='Security'.substring(0,i)+'<span class="tw-cursor"></span>';i++;setTimeout(t1,90)}else{l1.textContent='Security';t2()}}
  function t2(){if(j<='Researcher'.length){l2.innerHTML='Researcher'.substring(0,j)+'<span style="color:var(--accent)">.</span><span class="tw-cursor"></span>';j++;setTimeout(t2,90)}else{l2.innerHTML='Researcher<span style="color:var(--accent)">.</span>'}}
  setTimeout(t1,500);
</script>
