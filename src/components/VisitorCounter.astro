<section class="visitor" id="visitor">
  <div class="container">
    <div class="vis__badge" data-animate="scale">
      <div class="vis__badge-left">
        <span class="vis__dot"></span>
        <span class="vis__badge-label">NETWORK</span>
      </div>
      <div class="vis__badge-items">
        <div class="vis__item"><span class="vis__item-k">IP</span><span class="vis__item-v" id="vIP">scanning...</span></div>
        <div class="vis__sep"></div>
        <div class="vis__item"><span class="vis__item-k">LOC</span><span class="vis__item-v" id="vLoc">locating...</span></div>
        <div class="vis__sep"></div>
        <div class="vis__item"><span class="vis__item-k">ISP</span><span class="vis__item-v" id="vISP">resolving...</span></div>
        <div class="vis__sep"></div>
        <div class="vis__item vis__item--hl"><span class="vis__item-k">VISITORS</span><span class="vis__item-v vis__item-v--accent" id="vCount">---</span></div>
      </div>
      <span class="vis__badge-time" id="liveTime"></span>
    </div>
  </div>
</section>
<style>
  .visitor{padding:1rem 0 0}
  .vis__badge{display:flex;align-items:center;gap:1rem;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:.6rem 1.25rem;position:relative;overflow:hidden;flex-wrap:wrap}
  .vis__badge::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:.5}
  .vis__badge-left{display:flex;align-items:center;gap:.5rem;flex-shrink:0}
  .vis__dot{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 1.5s ease-in-out infinite;box-shadow:0 0 8px var(--accent-glow)}
  .vis__badge-label{font-family:var(--font-mono);font-size:.6rem;color:var(--accent);letter-spacing:.15em;font-weight:700}
  .vis__badge-items{display:flex;align-items:center;gap:.75rem;flex:1;min-width:0;flex-wrap:wrap}
  .vis__item{display:flex;align-items:center;gap:.4rem;min-width:0}
  .vis__item-k{font-family:var(--font-mono);font-size:.55rem;color:var(--text-muted);letter-spacing:.1em;flex-shrink:0}
  .vis__item-v{font-family:var(--font-mono);font-size:.75rem;color:var(--text-primary);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px}
  .vis__item-v--accent{color:var(--accent);font-weight:700;font-size:.85rem}
  .vis__sep{width:1px;height:16px;background:var(--border);flex-shrink:0}
  .vis__badge-time{font-family:var(--font-mono);font-size:.6rem;color:var(--text-muted);margin-left:auto;flex-shrink:0}

  @media(max-width:768px){
    .vis__badge{flex-direction:column;align-items:flex-start;gap:.6rem;padding:.75rem 1rem}
    .vis__badge-items{gap:.5rem}
    .vis__sep{display:none}
    .vis__item{flex-basis:calc(50% - .25rem)}
    .vis__item-v{max-width:140px;font-size:.7rem}
    .vis__badge-time{margin-left:0}
  }
  @media(max-width:400px){
    .vis__item{flex-basis:100%}
  }
</style>
<script>
  const ipE=document.getElementById('vIP'),locE=document.getElementById('vLoc'),ispE=document.getElementById('vISP'),cntE=document.getElementById('vCount'),timeE=document.getElementById('liveTime');
  function updTime(){const n=new Date();timeE.textContent=n.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit',second:'2-digit'})}
  setInterval(updTime,1000);updTime();

  async function fetchInfo(){
    try{
      const r=await fetch('https://ipapi.co/json/');const d=await r.json();
      ipE.textContent=d.ip||'unknown';
      locE.textContent=(d.city||'?')+', '+(d.country_name||'?');
      ispE.textContent=d.org||d.isp||'unknown';
    }catch(e){ipE.textContent='protected';locE.textContent='VPN active';ispE.textContent='—'}
  }
  async function fetchCount(){
    try{
      const r=await fetch('https://api.countapi.xyz/hit/ynsmroztas.github.io/visits');const d=await r.json();
      animC(d.value||0);
    }catch(e){let c=parseInt(localStorage.getItem('mv')||'0')+1;localStorage.setItem('mv',c.toString());animC(c)}
  }
  function animC(t){let s=performance.now();(function step(ts){const p=Math.min((ts-s)/1200,1);cntE.textContent=Math.floor((1-Math.pow(1-p,3))*t).toLocaleString();if(p<1)requestAnimationFrame(step)})(s)}
  setTimeout(()=>{fetchInfo();fetchCount()},600);
</script>
