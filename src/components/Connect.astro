---
const socials=[
  {name:"Twitter / X",handle:"@ynsmroztas",url:"https://twitter.com/ynsmroztas"},
  {name:"GitHub",handle:"@ynsmroztas",url:"https://github.com/ynsmroztas"},
  {name:"LinkedIn",handle:"@ynsmroztas",url:"https://linkedin.com/in/ynsmroztas"},
  {name:"Intigriti",handle:"@mitsec",url:"https://app.intigriti.com/profile/mitsec"},
  {name:"Instagram",handle:"@ynsmroztas",url:"https://instagram.com/ynsmroztas"},
  {name:"YouTube",handle:"@ynsmroztas",url:"https://youtube.com/@ynsmroztas"},
];
---
<section class="section connect" id="connect"><div class="container">
  <div class="conn__layout">
    <div data-animate="left">
      <span class="section-label">06 / Connect</span>
      <h2 class="section-title">Let's Work<br/>Together<span style="color:var(--accent)">.</span></h2>
      <p class="section-subtitle">Interested in collaboration, bug bounty programs, or security consulting?</p>
      <div class="conn__email"><span class="conn__email-l">Direct Email</span><a href="mailto:m.i.t@mit.tc" class="conn__email-a">m.i.t@mit.tc</a></div>
      <a href="mailto:m.i.t@mit.tc" class="btn btn--primary">Send Email ↗</a>
    </div>
    <div data-animate="right">
      <div class="conn__socials">{socials.map((s,i)=>(
        <a href={s.url} target="_blank" class="conn__card" style={`transition-delay:${i*.05}s`}>
          <div><span class="conn__name">{s.name}</span><span class="conn__handle">{s.handle}</span></div>
          <span class="conn__arrow">↗</span>
        </a>
      ))}</div>
    </div>
  </div>
</div></section>
<style>
  .conn__layout{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start}
  .conn__email{margin:2.5rem 0;padding:1.5rem 2rem;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);display:flex;flex-direction:column;gap:.5rem}
  .conn__email-l{font-family:var(--font-mono);font-size:.7rem;color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase}
  .conn__email-a{font-family:var(--font-mono);font-size:1.15rem;color:var(--accent);font-weight:600;transition:var(--transition-fast)}
  .conn__email-a:hover{text-shadow:0 0 15px var(--accent-glow)}
  .conn__socials{display:flex;flex-direction:column;gap:.5rem}
  .conn__card{display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);transition:var(--transition)}
  .conn__card:hover{border-color:var(--accent);background:var(--bg-card-hover);transform:translateX(8px)}
  .conn__card:hover .conn__arrow{color:var(--accent);transform:translate(3px,-3px)}
  .conn__name{display:block;font-weight:600;font-size:.95rem}
  .conn__handle{font-family:var(--font-mono);font-size:.75rem;color:var(--text-muted)}
  .conn__arrow{color:var(--text-muted);transition:var(--transition);font-size:1.1rem}
  @media(max-width:768px){.conn__layout{grid-template-columns:1fr;gap:2.5rem}}
</style>
