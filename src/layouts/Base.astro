---
const { title = "Yunus Emre Öztaş — Security Researcher & Bug Bounty Hunter", description = "Bug bounty hunter recognized by Apple, Microsoft, Meta & IBM. Intigriti Top Hacker." } = Astro.props;
const buildDate = new Date().toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta property="og:title" content={title}/><meta property="og:description" content={description}/>
  <meta property="og:type" content="website"/><meta property="og:url" content="https://ynsmroztas.github.io"/>
  <meta name="twitter:card" content="summary_large_image"/><meta name="twitter:site" content="@ynsmroztas"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
</head>
<body>
  <!-- ═══ BOOT SEQUENCE ═══ -->
  <div class="boot" id="bootScreen">
    <div class="boot__inner">
      <div class="boot__logo">[<span>mitsec</span>]</div>
      <div class="boot__terminal" id="bootTerminal"></div>
      <div class="boot__bar"><div class="boot__progress" id="bootProgress"></div></div>
      <div class="boot__pct" id="bootPct">0%</div>
    </div>
  </div>

  <!-- ═══ SCROLL PROGRESS ═══ -->
  <div class="scroll-progress" id="scrollProgress"></div>

  <canvas id="matrixCanvas"></canvas>
  <nav class="nav" id="nav">
    <div class="nav__inner container">
      <a href="#hero" class="nav__logo"><span class="nav__b">[</span><span class="nav__t">mitsec</span><span class="nav__b">]</span></a>
      <div class="nav__links" id="navLinks">
        <a href="#hof" class="nav__link">Hall of Fame</a>
        <a href="#tools" class="nav__link">Tools</a>
        <a href="#skills" class="nav__link">Skills</a>
        <a href="#cves" class="nav__link">CVEs</a>
        <a href="#blog" class="nav__link">Blog</a>
        <a href="#connect" class="nav__link">Connect</a>
      </div>
      <div class="nav__right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme"><span id="themeIcon">☀</span></button>
        <a href="mailto:m.i.t@mit.tc" class="btn btn--ghost nav__cta">Contact</a>
      </div>
      <button class="nav__toggle" id="navToggle" aria-label="Menu"><span></span><span></span></button>
    </div>
  </nav>
  <main><slot/></main>
  <footer class="footer"><div class="container footer__inner">
    <div class="footer__left">
      <span class="footer__logo">[mitsec]</span>
      <span class="footer__copy">© 2000–2026 Yunus Emre Öztaş</span>
    </div>
    <div class="footer__center">
      <span class="footer__updated">Last updated: {buildDate}</span>
    </div>
    <div class="footer__links">
      <a href="https://twitter.com/ynsmroztas" target="_blank">Twitter</a>
      <a href="https://github.com/ynsmroztas" target="_blank">GitHub</a>
      <a href="https://linkedin.com/in/ynsmroztas" target="_blank">LinkedIn</a>
      <a href="https://app.intigriti.com/profile/mitsec" target="_blank">Intigriti</a>
    </div>
  </div></footer>

  <style>
    /* ═══ BOOT SEQUENCE ═══ */
    .boot{position:fixed;inset:0;z-index:99999;background:#0a0a0f;display:flex;align-items:center;justify-content:center;transition:opacity .5s,visibility .5s}
    .boot.done{opacity:0;visibility:hidden;pointer-events:none}
    .boot__inner{width:min(500px,90vw);text-align:center}
    .boot__logo{font-family:var(--font-mono,'JetBrains Mono',monospace);font-size:clamp(1.4rem,4vw,2rem);font-weight:700;color:#00ff88;margin-bottom:2rem;letter-spacing:-.02em}
    .boot__logo span{color:#e8e6f0}
    .boot__terminal{font-family:var(--font-mono,'JetBrains Mono',monospace);font-size:.7rem;line-height:1.9;color:#8a88a0;text-align:left;min-height:160px;padding:1rem;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:8px;margin-bottom:1.5rem;overflow:hidden}
    .boot__terminal .bp{color:#00ff88}.boot__terminal .bo{color:#ffa502}.boot__terminal .bs{color:#3b82f6}
    .boot__bar{width:100%;height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;margin-bottom:.75rem}
    .boot__progress{height:100%;width:0%;background:linear-gradient(90deg,#00ff88,#7b61ff);border-radius:2px;transition:width .15s linear}
    .boot__pct{font-family:var(--font-mono,'JetBrains Mono',monospace);font-size:.7rem;color:#55536a}

    /* ═══ SCROLL PROGRESS ═══ */
    .scroll-progress{position:fixed;top:0;left:0;height:2px;width:0%;background:linear-gradient(90deg,var(--accent),var(--accent-secondary));z-index:10001;pointer-events:none;transition:width .05s linear}

    #matrixCanvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:var(--matrix-opacity)}

    /* ═══ NAV ═══ */
    .nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1rem 0;transition:var(--transition);backdrop-filter:blur(20px);background:rgba(10,10,15,.8);border-bottom:1px solid transparent}
    html.light .nav{background:rgba(245,245,240,.85)}
    .nav--scrolled{border-bottom-color:var(--border)}
    .nav__inner{display:flex;align-items:center;justify-content:space-between}
    .nav__logo{font-family:var(--font-mono);font-size:1.1rem;font-weight:700;display:flex;gap:.15rem}
    .nav__logo:hover .nav__t{color:var(--accent)}.nav__b{color:var(--accent)}.nav__t{color:var(--text-primary);transition:var(--transition-fast)}
    .nav__links{display:flex;gap:2.5rem}
    .nav__link{font-family:var(--font-mono);font-size:.8rem;color:var(--text-secondary);letter-spacing:.03em;transition:var(--transition-fast);position:relative}
    .nav__link::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--accent);transition:var(--transition)}
    .nav__link:hover{color:var(--accent)}.nav__link:hover::after{width:100%}
    .nav__right{display:flex;align-items:center;gap:1rem}.nav__cta{padding:.5rem 1.25rem;font-size:.8rem}
    .theme-toggle{background:var(--accent-dim);border:1px solid rgba(0,255,136,.1);border-radius:var(--radius-sm);width:36px;height:36px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:var(--transition);font-size:1rem}
    .theme-toggle:hover{border-color:var(--accent);box-shadow:0 0 15px var(--accent-dim)}
    .nav__toggle{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px}
    .nav__toggle span{display:block;width:22px;height:2px;background:var(--text-primary);transition:var(--transition)}
    .nav__toggle.active span:first-child{transform:rotate(45deg) translate(3px,3px)}
    .nav__toggle.active span:last-child{transform:rotate(-45deg) translate(3px,-3px)}

    /* ═══ FOOTER ═══ */
    .footer{border-top:1px solid var(--border);padding:2.5rem 0}
    .footer__inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
    .footer__left{display:flex;align-items:center;gap:1.5rem}
    .footer__logo{font-family:var(--font-mono);font-weight:700;color:var(--accent);font-size:.9rem}
    .footer__copy{color:var(--text-muted);font-size:.8rem}
    .footer__center{flex:1;text-align:center}
    .footer__updated{font-family:var(--font-mono);font-size:.65rem;color:var(--text-muted);letter-spacing:.05em;opacity:.6}
    .footer__links{display:flex;gap:2rem}
    .footer__links a{color:var(--text-secondary);font-size:.8rem;font-family:var(--font-mono);transition:var(--transition-fast)}
    .footer__links a:hover{color:var(--accent)}

    @media(max-width:768px){
      .nav__links{display:none;position:absolute;top:100%;left:0;right:0;flex-direction:column;background:var(--bg-secondary);border-bottom:1px solid var(--border);padding:1.5rem var(--gutter);gap:1.25rem;backdrop-filter:blur(20px)}
      .nav__links.open{display:flex}
      .nav__cta{display:none}
      .nav__toggle{display:flex}
      .footer__inner{flex-direction:column;gap:1rem;text-align:center}
      .footer__left{flex-direction:column;gap:.5rem}
      .footer__center{order:3}
      .footer__links{flex-wrap:wrap;justify-content:center;gap:1rem}
    }
  </style>

  <script>
    // ═══ BOOT SEQUENCE ═══
    (function(){
      const bootEl=document.getElementById('bootScreen');
      const termEl=document.getElementById('bootTerminal');
      const progEl=document.getElementById('bootProgress');
      const pctEl=document.getElementById('bootPct');
      if(sessionStorage.getItem('booted')){bootEl?.remove();return}

      const lines=[
        {t:'bp',m:'[kernel]',d:'mitsec OS v4.2.0 — initializing...'},
        {t:'bs',m:'[system]',d:'Loading security modules...'},
        {t:'bp',m:'[net]',d:'Establishing encrypted connection...'},
        {t:'bs',m:'[auth]',d:'Verifying SSL certificates — ✓ valid'},
        {t:'bo',m:'[scan]',d:'Running threat assessment...'},
        {t:'bp',m:'[tools]',d:'Mounting /usr/lib/frida — OK'},
        {t:'bp',m:'[tools]',d:'Mounting /usr/lib/burpsuite — OK'},
        {t:'bs',m:'[recon]',d:'Loading reconnaissance framework...'},
        {t:'bo',m:'[vuln]',d:'CVE database synced — 2,430+ entries'},
        {t:'bp',m:'[ui]',d:'Rendering interface...'},
        {t:'bs',m:'[ready]',d:'All systems operational. Welcome, visitor.'},
      ];

      let i=0;
      function addLine(){
        if(i>=lines.length){
          setTimeout(()=>{bootEl.classList.add('done');sessionStorage.setItem('booted','1');setTimeout(()=>bootEl.remove(),600)},400);
          return;
        }
        const l=lines[i];
        const div=document.createElement('div');
        div.innerHTML='<span class="'+l.t+'">'+l.m+'</span> '+l.d;
        termEl.appendChild(div);
        termEl.scrollTop=termEl.scrollHeight;
        const pct=Math.round(((i+1)/lines.length)*100);
        progEl.style.width=pct+'%';
        pctEl.textContent=pct+'%';
        i++;
        setTimeout(addLine,130+Math.random()*90);
      }
      setTimeout(addLine,300);
    })();

    // ═══ MATRIX RAIN ═══
    const canvas=document.getElementById('matrixCanvas'),ctx=canvas.getContext('2d');
    let w,h,cols,drops=[];
    const chars='01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン';
    function initM(){w=canvas.width=window.innerWidth;h=canvas.height=window.innerHeight;cols=Math.floor(w/18);drops=Array(cols).fill(1)}
    function drawM(){ctx.fillStyle=document.documentElement.classList.contains('light')?'rgba(245,245,240,.08)':'rgba(10,10,15,.06)';ctx.fillRect(0,0,w,h);ctx.fillStyle=getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();ctx.font='14px monospace';for(let i=0;i<drops.length;i++){ctx.globalAlpha=Math.random()*.5+.1;ctx.fillText(chars[Math.floor(Math.random()*chars.length)],i*18,drops[i]*18);ctx.globalAlpha=1;if(drops[i]*18>h&&Math.random()>.975)drops[i]=0;drops[i]++}requestAnimationFrame(drawM)}
    initM();drawM();window.addEventListener('resize',initM);

    // ═══ SCROLL PROGRESS BAR ═══
    const scrollBar=document.getElementById('scrollProgress');
    window.addEventListener('scroll',()=>{
      const total=document.documentElement.scrollHeight-window.innerHeight;
      if(total>0) scrollBar.style.width=(window.scrollY/total*100)+'%';
    },{passive:true});

    // ═══ NAV ═══
    const nav=document.getElementById('nav');
    window.addEventListener('scroll',()=>nav?.classList.toggle('nav--scrolled',window.scrollY>50),{passive:true});
    const navToggle=document.getElementById('navToggle');
    const navLinks=document.getElementById('navLinks');
    navToggle?.addEventListener('click',()=>{navLinks?.classList.toggle('open');navToggle.classList.toggle('active')});
    document.querySelectorAll('.nav__link').forEach(l=>l.addEventListener('click',()=>{navLinks?.classList.remove('open');navToggle?.classList.remove('active')}));

    // ═══ THEME ═══
    const saved=localStorage.getItem('theme');if(saved==='light')document.documentElement.classList.add('light');
    function upIcon(){document.getElementById('themeIcon').textContent=document.documentElement.classList.contains('light')?'🌙':'☀'}upIcon();
    document.getElementById('themeToggle')?.addEventListener('click',()=>{document.documentElement.classList.toggle('light');localStorage.setItem('theme',document.documentElement.classList.contains('light')?'light':'dark');upIcon()});

    // ═══ SCROLL ANIMATIONS ═══
    const obs=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('is-visible');obs.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('[data-animate]').forEach(el=>obs.observe(el));

    // ═══ LAZY LOADING ═══
    if('loading' in HTMLImageElement.prototype){
      document.querySelectorAll('img[data-src]').forEach(img=>{img.src=img.dataset.src;img.removeAttribute('data-src')});
    } else {
      const imgObs=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.src=e.target.dataset.src;e.target.removeAttribute('data-src');imgObs.unobserve(e.target)}})},{rootMargin:'200px'});
      document.querySelectorAll('img[data-src]').forEach(img=>imgObs.observe(img));
    }
    document.querySelectorAll('iframe[data-src]').forEach(f=>{
      const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.src=e.target.dataset.src;e.target.removeAttribute('data-src');io.unobserve(e.target)}})},{rootMargin:'300px'});
      io.observe(f);
    });
  </script>
</body>
</html>
